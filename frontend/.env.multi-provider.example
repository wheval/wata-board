# Multi-Provider Frontend Configuration Example
# Copy this file to .env and configure your frontend

# API Configuration
VITE_API_URL=http://localhost:3001
VITE_FRONTEND_URL=http://localhost:5173

# Stellar Configuration
VITE_CONTRACT_ID=CDRRJ7IPYDL36YSK5ZQLBG3LICULETIBXX327AGJQNTWXNKY2UMDO4DA
VITE_RPC_URL=https://soroban-testnet.stellar.org

# Network Configuration
VITE_NETWORK=testnet

# Multi-Provider Configuration
VITE_ENABLE_MULTI_PROVIDER=true
VITE_DEFAULT_PROVIDER_ID=wata-board

# Feature Flags
VITE_ENABLE_PROVIDER_SELECTION=true
VITE_ENABLE_PROVIDER_ANALYTICS=false
VITE_ENABLE_ADMIN_PANEL=false

# UI Configuration
VITE_APP_NAME=Wata-Board
VITE_APP_VERSION=2.0.0
VITE_SUPPORT_EMAIL=support@wata-board.com

# Theme Configuration
VITE_DEFAULT_THEME=system
VITE_ENABLE_DARK_MODE=true

# Localization
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,hi,ja,pa,pt,ru

# Analytics and Monitoring
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# Development Configuration
VITE_DEV_TOOLS=true
VITE_LOG_LEVEL=debug

# Production Configuration (uncomment for production)
# VITE_API_URL=https://api.wata-board.com
# VITE_FRONTEND_URL=https://wata-board.com
# VITE_NETWORK=mainnet
# VITE_DEV_TOOLS=false
# VITE_LOG_LEVEL=error
