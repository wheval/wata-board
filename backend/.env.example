# Environment Variables for Wata Board DApp
# Copy this file to .env and fill in your actual values

# Server Configuration
# Port for the API server (default: 3001)
PORT=3001

# Environment (development, production)
NODE_ENV=development

# SSL Configuration
# Enable HTTPS in production (set to 'true' for production with SSL)
HTTPS_ENABLED=false

# SSL certificate paths (only needed when HTTPS_ENABLED=true)
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_CA_PATH=/etc/letsencrypt/live/yourdomain.com/chain.pem

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Examples: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL for production deployment
FRONTEND_URL=https://your-frontend-domain.com

# Network Configuration
# Options: testnet, mainnet
NETWORK=testnet

# Secure Key Management Configuration
# Master password for decrypting the admin secret key (recommended for production)
# This password is used to encrypt/decrypt the admin secret key stored securely
# IMPORTANT: Use a strong, unique password and store it securely (e.g., password manager)
KEY_MASTER_PASSWORD=your_strong_master_password_here

# Stellar secret key for the admin account (LEGACY - not recommended)
# This key controls access to administrative functions of the smart contract
# IMPORTANT: Never commit this file to version control or share the secret key
# DEPRECATED: Use secure key management with KEY_MASTER_PASSWORD instead
ADMIN_SECRET_KEY=your_stellar_secret_key_here

# Contract Configuration
# The contract ID for the Wata Board smart contract on Stellar network
# These will be automatically selected based on NETWORK, but you can override them
CONTRACT_ID_TESTNET=CDRRJ7IPYDL36YSK5ZQLBG3LICULETIBXX327AGJQNTWXNKY2UMDO4DA
CONTRACT_ID_MAINNET=MAINNET_CONTRACT_ID_HERE

# Stellar RPC URL
# The RPC endpoint for connecting to the Stellar Soroban network
# These will be automatically selected based on NETWORK, but you can override them
RPC_URL_TESTNET=https://soroban-testnet.stellar.org
RPC_URL_MAINNET=https://soroban.stellar.org

# Network Configuration
# Network passphrase for Stellar network
# These will be automatically selected based on NETWORK, but you can override them
NETWORK_PASSPHRASE_TESTNET=Test SDF Network ; September 2015
NETWORK_PASSPHRASE_MAINNET=Public Global Stellar Network ; September 2015
